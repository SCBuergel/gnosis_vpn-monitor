#!/usr/bin/env python3
"""Record and plot gnosisVPN ping/curl traces.

Three subcommands:

    ping HOST   record ping latency to a host
    curl URL    record curl download throughput
    plot FILE   render an SVG chart from a recording

The recordings are plain text files: one timestamped sample per line,
shaped like `[<unix-seconds>.<microseconds>] <payload>`. Both recorders
write to stdout so you can `tee` or redirect the output, and accept an
optional `-o PATH` to additionally tee a copy into a file.

The script depends only on the Python 3 standard library — no `pip
install` required. The recorders shell out to `ping` and `curl`; the
plotter has no external dependencies at all. See README.md for examples.
"""

import argparse
import math
import os
import re
import shutil
import subprocess
import sys
import time
from datetime import datetime


# ---------------------------------------------------------------------------
# Project layout
# ---------------------------------------------------------------------------
#
# Recordings live under data/ next to the script; rendered SVGs go under
# output/. Resolved relative to the script location (not the cwd) so the
# tool behaves the same regardless of where the user invokes it from.

PROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))
DATA_DIR = os.path.join(PROJECT_ROOT, "data")
OUTPUT_DIR = os.path.join(PROJECT_ROOT, "output")


# ---------------------------------------------------------------------------
# Recording defaults
# ---------------------------------------------------------------------------

# Sensible defaults so a bare `./gnosis_vpn-monitor ping` / `curl` does
# something useful. Override on the command line for real measurements.
DEFAULT_PING_HOST = "google.com"
DEFAULT_CURL_URL = (
    "https://cdn.kernel.org/pub/linux/kernel/v7.x/linux-7.0.5.tar.xz"
)
DEFAULT_PING_FILE = os.path.join(DATA_DIR, "ping.txt")
DEFAULT_CURL_FILE = os.path.join(DATA_DIR, "curl.txt")


# ---------------------------------------------------------------------------
# Parsing
# ---------------------------------------------------------------------------
#
# Both recording formats start each data line with "[<unix-seconds>...]".
# `ping -D` writes "[1778315104.443890]" while older curl recordings made
# with the awk wrapper contain "[1778315899.   %6N]" on systems whose
# strftime lacks the GNU `%N` extension. We accept both: the regex
# captures integer seconds plus an optional fractional part, and skips
# whatever follows up to the closing bracket. Recordings produced by this
# script's `curl` subcommand always have full microsecond precision.

TIMESTAMP_RE = re.compile(r"\[(\d+(?:\.\d+)?)[^\]]*\]")

# `ping -D` reports latency as "time=177 ms".
PING_TIME_RE = re.compile(r"time=([\d.]+)\s*ms")

# `curl` progress lines end with a current-speed token, e.g. "84137",
# "359k", "1.2M" or "0". (The trailing "k"/"M"/"G" are 1024-based, matching
# curl's own convention.)
CURL_SPEED_RE = re.compile(r"^(\d+(?:\.\d+)?)([kMG]?)$")
SPEED_UNIT_BYTES = {"": 1, "k": 1024, "M": 1024 ** 2, "G": 1024 ** 3}


def parse_speed(token):
    """Return a curl speed token in bytes/second, or None if unparseable."""
    m = CURL_SPEED_RE.match(token)
    if not m:
        return None
    return float(m.group(1)) * SPEED_UNIT_BYTES[m.group(2)]


def parse_recording(path):
    """Parse a ping or curl recording.

    Returns a tuple ``(kind, points)`` where ``kind`` is ``"ping"`` (RTT in
    ms) or ``"curl"`` (speed in bytes/s) and ``points`` is a list of
    ``(unix_timestamp, value)`` pairs in file order.

    Lines that don't match either format are silently skipped, which makes
    the parser robust to header rows, blank lines, and the cosmetic noise
    curl emits during connection setup.
    """
    points = []
    kind = None

    with open(path) as f:
        for line in f:
            ts_match = TIMESTAMP_RE.search(line)
            if not ts_match:
                continue
            t = float(ts_match.group(1))
            rest = line[ts_match.end():]

            ping_match = PING_TIME_RE.search(rest)
            if ping_match:
                points.append((t, float(ping_match.group(1))))
                kind = "ping"
                continue

            tokens = rest.split()
            if tokens:
                speed = parse_speed(tokens[-1])
                if speed is not None:
                    points.append((t, speed))
                    kind = "curl"

    if not points:
        raise ValueError(f"no recognisable ping or curl data in {path}")
    return kind, points


# ---------------------------------------------------------------------------
# Value formatting
# ---------------------------------------------------------------------------

def format_ms(v):
    """Tick label for a millisecond value (e.g. 17.1, 100, 250)."""
    if v == 0:
        return "0"
    # %g drops trailing zeros — "20" rather than "20.0", "17.1" rather than "17.10".
    return f"{v:g}"


def format_bytes_per_second(v):
    """Tick label for a bytes-per-second value, using decimal SI prefixes
    (1k = 1000) so labels for round tick values come out clean: a tick at
    5_000_000 reads "5M" rather than the binary-1024 equivalent "4.8M"."""
    if v <= 0:
        return "0"
    for unit, suffix in ((1e9, "G"), (1e6, "M"), (1e3, "k")):
        if v >= unit:
            return f"{v / unit:.3g}{suffix}"
    return f"{v:.0f}"


KIND_LABEL = {"ping": "RTT (ms)", "curl": "Speed (B/s)"}
KIND_FORMATTER = {"ping": format_ms, "curl": format_bytes_per_second}


# ---------------------------------------------------------------------------
# Style parsing (matplotlib-style format strings: "xb", "o-r", ".--g", …)
# ---------------------------------------------------------------------------
#
# Format strings combine three pieces, in any order:
#   linestyle: "-" solid, "--" dashed, "-." dash-dot, ":" dotted, or absent
#   marker:    . o x + * s D ^ v   (subset of matplotlib's marker codes)
#   color:     b g r c m y k w     (the eight one-letter colours)
# Anything else raises ValueError so typos are caught early.

COLOR_MAP = {
    "b": "blue",      "g": "green",      "r": "red",       "c": "cyan",
    "m": "magenta",   "y": "olive",      "k": "black",     "w": "white",
}

LINESTYLE_DASH = {
    "-":  None,        # solid (no dash array)
    "--": "12,6",      # dashed
    "-.": "10,5,2,5",  # dash-dot
    ":":  "0,6",       # dotted (relies on stroke-linecap=round, set on the path)
}

# Marker glyphs as <g> templates. Each is centred on (0, 0); the <use>
# element's x/y attributes translate the glyph to a data point's pixel
# position, and `currentColor` picks up the colour from the <use>'s
# `color` attribute. Sizes are tuned for the default 1800×840 chart.
MARKER_DEFS = {
    ".": '<g id="m-dot"><circle r="3" fill="currentColor"/></g>',
    "o": '<g id="m-circle"><circle r="6" fill="none" stroke="currentColor" stroke-width="2"/></g>',
    "x": '<g id="m-x"><path d="M-6,-6L6,6M-6,6L6,-6" stroke="currentColor" stroke-width="2" fill="none"/></g>',
    "+": '<g id="m-plus"><path d="M-6,0L6,0M0,-6L0,6" stroke="currentColor" stroke-width="2" fill="none"/></g>',
    "s": '<g id="m-square"><rect x="-5" y="-5" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"/></g>',
    "D": '<g id="m-diamond"><polygon points="0,-7 6,0 0,7 -6,0" fill="none" stroke="currentColor" stroke-width="2"/></g>',
    "^": '<g id="m-tri-up"><polygon points="0,-7 6,5 -6,5" fill="none" stroke="currentColor" stroke-width="2"/></g>',
    "v": '<g id="m-tri-down"><polygon points="0,7 6,-5 -6,-5" fill="none" stroke="currentColor" stroke-width="2"/></g>',
    "*": '<g id="m-star"><polygon points="0,-7 1.6,-2.2 6.7,-2.2 2.7,0.8 4.1,5.7 0,2.8 -4.1,5.7 -2.7,0.8 -6.7,-2.2 -1.6,-2.2" fill="currentColor"/></g>',
}

MARKER_HREFS = {
    ".": "#m-dot",     "o": "#m-circle",    "x": "#m-x",      "+": "#m-plus",
    "s": "#m-square",  "D": "#m-diamond",   "^": "#m-tri-up", "v": "#m-tri-down",
    "*": "#m-star",
}

DEFAULT_COLOR_CODE = "b"  # used when a style string has no colour


def parse_style(spec):
    """Parse a matplotlib-style format string into (linestyle, marker, color).

    Each component is optional. ``linestyle`` and ``marker`` come back as
    None when absent; ``color`` is normalised to its CSS name (defaulting
    to blue when the spec doesn't include a colour code).
    """
    linestyle = marker = color = None
    i = 0
    while i < len(spec):
        # Two-character linestyles must be matched before the single "-".
        if spec[i:i + 2] in ("--", "-."):
            if linestyle is not None:
                raise ValueError(f"duplicate linestyle in style {spec!r}")
            linestyle = spec[i:i + 2]
            i += 2
            continue
        ch = spec[i]
        if ch in ("-", ":"):
            if linestyle is not None:
                raise ValueError(f"duplicate linestyle in style {spec!r}")
            linestyle = ch
        elif ch in MARKER_DEFS:
            if marker is not None:
                raise ValueError(f"duplicate marker in style {spec!r}")
            marker = ch
        elif ch in COLOR_MAP:
            if color is not None:
                raise ValueError(f"duplicate colour in style {spec!r}")
            color = ch
        else:
            raise ValueError(
                f"unknown character {ch!r} in style {spec!r} — "
                "expected one of linestyle (- -- -. :), "
                f"marker ({' '.join(sorted(MARKER_DEFS))}), "
                f"or colour ({' '.join(COLOR_MAP)})"
            )
        i += 1
    return linestyle, marker, COLOR_MAP[color or DEFAULT_COLOR_CODE]


# ---------------------------------------------------------------------------
# Tick generation
# ---------------------------------------------------------------------------

def nice_step(raw):
    """Pick a 'nice' tick step — 1, 2, 5 or 10 × 10^k — close to `raw`.

    This is the standard cartographic/plotting heuristic: round the
    requested spacing to a nearby value whose mantissa is 1, 2, 5 or 10
    so tick labels land on visually clean values (10, 20, 50, 100, …
    rather than 9, 18, 45, 90).
    """
    if raw <= 0:
        return 1
    mag = 10 ** math.floor(math.log10(raw))
    norm = raw / mag
    if norm <= 1.5:
        return 1 * mag
    if norm <= 3:
        return 2 * mag
    if norm <= 7:
        return 5 * mag
    return 10 * mag


def linear_ticks(lo, hi, n=5):
    """Return ~n tick values inside [lo, hi] at nice round increments."""
    if hi <= lo:
        return [lo]
    step = nice_step((hi - lo) / n)
    out = []
    v = math.ceil(lo / step) * step
    # The 1e-9 slack prevents floating-point error from dropping the last tick.
    while v <= hi + step * 1e-9:
        # Snap "should-be-zero" results to exactly 0 to suppress -0.0
        # and the long tail of fp dust on what looks like a clean number.
        out.append(0 if abs(v) < step * 1e-9 else round(v, 12))
        v += step
    return out


def log_decade_ticks(lo, hi):
    """Decade tick values (..., 1, 10, 100, ...) that fall inside [lo, hi].

    Only decades actually visible on the axis are returned, so we never
    place a "10" label below the chart frame for a 75–800 axis.
    """
    if lo <= 0 or hi <= 0:
        return []
    lo_e = math.ceil(math.log10(lo) - 1e-9)
    hi_e = math.floor(math.log10(hi) + 1e-9)
    if hi_e < lo_e:
        return []
    return [10 ** e for e in range(lo_e, hi_e + 1)]


def log_minor_ticks(lo, hi):
    """Within-decade ticks (2..9 × 10^k) that fall inside [lo, hi].

    These are the "200, 300, … 900" subdivisions that make a tightly
    ranged log axis legible — without them a 100→1000 axis has only the
    two endpoint labels for reference.
    """
    if lo <= 0 or hi <= 0:
        return []
    lo_e = math.floor(math.log10(lo))
    hi_e = math.ceil(math.log10(hi))
    out = []
    for e in range(lo_e, hi_e + 1):
        base = 10 ** e
        for m in range(2, 10):
            v = m * base
            if lo <= v <= hi:
                out.append(v)
    return out


# ---------------------------------------------------------------------------
# Axes
# ---------------------------------------------------------------------------

class Axis:
    """A y-axis: holds the value→pixel transform plus tick layout.

    Linear axes pick a "nice" step from the data range and snap their
    bounds to multiples of that step, so the topmost and bottommost
    ticks land exactly on the chart frame at round values. Tight data
    ranges therefore zoom in (a 110–170 ms ping trace ticks at every
    10 ms instead of being squished against a 0–200 ms axis).

    Log axes use one decade of headroom on either side of the data and
    skip non-positive samples. Decade ticks are filtered to the visible
    range, and within-decade minor ticks (2 × 10^k … 9 × 10^k) are added
    when the axis spans fewer than ~3 decades — so the user can tell
    apart 200, 300, 400 etc. without scrabbling for a ruler. Past
    ~3 decades the minor ticks become noise and are dropped, leaving
    decade markers to carry the chart.
    """

    # Threshold (axis decades, post-padding) below which minor ticks are
    # drawn. Picked so the canonical ping/curl ranges (~1–2 decades) get
    # subdivisions but a 5-decade-wide chart doesn't.
    _MINOR_TICK_DECADE_LIMIT = 4

    def __init__(self, kind, values, log=False):
        self.kind = kind
        self.label = KIND_LABEL[kind]
        self.format = KIND_FORMATTER[kind]
        self.log = log

        if log:
            positive = [v for v in values if v > 0]
            if not positive:
                raise ValueError(f"cannot log-scale {kind}: no positive samples")
            self.lo = min(positive) / 2
            self.hi = max(positive) * 2
            self.lo_t = math.log10(self.lo)
            self.hi_t = math.log10(self.hi)
            self._show_minor = (self.hi_t - self.lo_t) < self._MINOR_TICK_DECADE_LIMIT
            self._step = None
        else:
            vmin, vmax = min(values), max(values)
            if vmin == vmax:
                # Constant series: invent a 1-unit window so the chart still draws.
                vmin -= 0.5
                vmax += 0.5
            self._step = nice_step((vmax - vmin) / 5)
            self.lo = math.floor(vmin / self._step) * self._step
            self.hi = math.ceil(vmax / self._step) * self._step
            if self.hi == self.lo:
                self.hi = self.lo + self._step
            self.lo_t = self.lo
            self.hi_t = self.hi
            self._show_minor = False

    def transform(self, v):
        """Map a data value to its position on the (transformed) axis."""
        if self.log:
            # Clamp to keep paths inside the plot for v near or below lo.
            return math.log10(max(v, self.lo))
        return v

    def is_visible(self, v):
        """True if a sample can be drawn on this axis."""
        return not self.log or v > 0

    def major_ticks(self):
        """Labelled ticks: decades for log, snapped multiples for linear."""
        if self.log:
            decades = log_decade_ticks(self.lo, self.hi)
            if decades:
                return decades
            # No decade fits inside a very tight log range — promote the
            # minor ticks so the axis still gets some labels.
            return log_minor_ticks(self.lo, self.hi)
        return linear_ticks(self.lo, self.hi)

    def minor_ticks(self):
        """Unlabelled subdivision marks. Linear axes have none."""
        if not self.log or not self._show_minor:
            return []
        if not log_decade_ticks(self.lo, self.hi):
            # All ticks were already promoted to major (above).
            return []
        return log_minor_ticks(self.lo, self.hi)


# ---------------------------------------------------------------------------
# SVG rendering
# ---------------------------------------------------------------------------

# Chart geometry. Values are pixels. Defaults are sized for high-DPI viewing
# (~2× the original 900×420 prototype) and can be overridden per-invocation
# via the --width / --height CLI flags.
DEFAULT_WIDTH = 1800
DEFAULT_HEIGHT = 840
MARGIN_LEFT = 80
MARGIN_RIGHT = 80      # leaves room for an optional second y-axis
MARGIN_TOP = 30
MARGIN_BOTTOM = 50

FONT_SIZE = 14         # tick labels and axis titles
STROKE_WIDTH = 3       # data series polyline

# Default --style values (see Style parsing section). One entry per series
# slot, so a double-y chart gets visually distinct colours by default
# while a single-series chart uses the user's one-string default.
DEFAULT_STYLES = ["xb", "xr"]


class Plot:
    """SVG geometry helper. One instance corresponds to one chart."""

    def __init__(self, x0, x1, width=DEFAULT_WIDTH, height=DEFAULT_HEIGHT):
        self.x0 = x0
        self.x1 = x1
        self.width = width
        self.height = height

    def x_pixel(self, x):
        if self.x1 == self.x0:
            return MARGIN_LEFT
        span = self.width - MARGIN_LEFT - MARGIN_RIGHT
        return MARGIN_LEFT + (x - self.x0) / (self.x1 - self.x0) * span

    def y_pixel(self, y, axis):
        v = axis.transform(y)
        span = self.height - MARGIN_TOP - MARGIN_BOTTOM
        return self.height - MARGIN_BOTTOM - (v - axis.lo_t) / (axis.hi_t - axis.lo_t) * span

    # --- Skeleton -----------------------------------------------------------

    def header(self):
        # viewBox lets the SVG scale cleanly when embedded at non-native
        # sizes (browsers, Markdown viewers, the rsvg→PNG step).
        return [
            f'<svg xmlns="http://www.w3.org/2000/svg" '
            f'width="{self.width}" height="{self.height}" '
            f'viewBox="0 0 {self.width} {self.height}" '
            f'font-family="sans-serif" font-size="{FONT_SIZE}">',
            f'<rect width="{self.width}" height="{self.height}" fill="white"/>',
        ]

    @staticmethod
    def footer():
        return ["</svg>"]

    def frame(self, left_color="black", right_color="black"):
        """Draw the four edges of the plot area as separate lines so the
        left and right verticals can be tinted to match their series.

        Top and bottom stay black: they're shared between both axes and
        belong to the chart's chrome rather than to either series.
        """
        L = MARGIN_LEFT
        R = self.width - MARGIN_RIGHT
        T = MARGIN_TOP
        B = self.height - MARGIN_BOTTOM
        return [
            f'<line x1="{L}" y1="{T}" x2="{R}" y2="{T}" stroke="black"/>',
            f'<line x1="{L}" y1="{B}" x2="{R}" y2="{B}" stroke="black"/>',
            f'<line x1="{L}" y1="{T}" x2="{L}" y2="{B}" stroke="{left_color}"/>',
            f'<line x1="{R}" y1="{T}" x2="{R}" y2="{B}" stroke="{right_color}"/>',
        ]

    # --- X axis (time) ------------------------------------------------------

    def x_axis(self):
        out = []
        bottom = self.height - MARGIN_BOTTOM
        for x in linear_ticks(self.x0, self.x1):
            px = self.x_pixel(x)
            out.append(
                f'<line x1="{px}" y1="{bottom}" x2="{px}" y2="{bottom + 4}" '
                f'stroke="black"/>'
            )
            label = datetime.fromtimestamp(x).strftime("%H:%M:%S")
            out.append(
                f'<text x="{px}" y="{bottom + 18}" text-anchor="middle">{label}</text>'
            )
        cx = (MARGIN_LEFT + self.width - MARGIN_RIGHT) / 2
        out.append(f'<text x="{cx}" y="{self.height - 10}" text-anchor="middle">time</text>')
        return out

    # --- Y axis -------------------------------------------------------------

    def y_axis(self, axis, side, color):
        """Render gridlines, tick labels and the axis title for one y-axis.

        `side` is ``"left"`` or ``"right"``. Gridlines are only drawn for
        the left axis to keep a double-y chart from looking like a fishnet.

        Minor ticks (subdivisions inside a decade on a log axis) get
        short marks but no label and no gridline — they're visual
        rulers for reading off intermediate values, not labelled stops.
        """
        out = []
        left = MARGIN_LEFT
        right = self.width - MARGIN_RIGHT

        # Minor ticks first (they sit visually behind the major marks).
        for v in axis.minor_ticks():
            py = self.y_pixel(v, axis)
            if side == "left":
                out.append(
                    f'<line x1="{left - 2}" y1="{py}" x2="{left}" y2="{py}" '
                    f'stroke="{color}"/>'
                )
            else:
                out.append(
                    f'<line x1="{right}" y1="{py}" x2="{right + 2}" y2="{py}" '
                    f'stroke="{color}"/>'
                )

        # Major ticks: longer mark, gridline (left axis only), label.
        for v in axis.major_ticks():
            py = self.y_pixel(v, axis)
            if side == "left":
                out.append(
                    f'<line x1="{left - 4}" y1="{py}" x2="{left}" y2="{py}" '
                    f'stroke="{color}"/>'
                )
                out.append(
                    f'<line x1="{left}" y1="{py}" x2="{right}" y2="{py}" stroke="#eee"/>'
                )
                out.append(
                    f'<text x="{left - 6}" y="{py + 4}" text-anchor="end" '
                    f'fill="{color}">{axis.format(v)}</text>'
                )
            else:
                out.append(
                    f'<line x1="{right}" y1="{py}" x2="{right + 4}" y2="{py}" '
                    f'stroke="{color}"/>'
                )
                out.append(
                    f'<text x="{right + 6}" y="{py + 4}" text-anchor="start" '
                    f'fill="{color}">{axis.format(v)}</text>'
                )

        cy = (MARGIN_TOP + self.height - MARGIN_BOTTOM) / 2
        x = left - 55 if side == "left" else right + 55
        out.append(
            f'<text x="{x}" y="{cy}" transform="rotate(-90 {x},{cy})" '
            f'text-anchor="middle" fill="{color}">{axis.label}</text>'
        )
        return out

    # --- Data series --------------------------------------------------------

    def series(self, points, axis, color, linestyle=None, marker=None):
        """Render one series.

        Samples invisible on `axis` (e.g. zero/negative on a log axis)
        are dropped. If ``linestyle`` is set, the points are joined by a
        polyline with the matching dash pattern. If ``marker`` is set,
        a marker glyph is placed at every visible point.
        """
        visible = [(x, y) for x, y in points if axis.is_visible(y)]
        if not visible:
            return []

        out = []
        coords = [(self.x_pixel(x), self.y_pixel(y, axis)) for x, y in visible]

        if linestyle is not None:
            path = "M " + " L ".join(f"{px:.1f},{py:.1f}" for px, py in coords)
            attrs = [
                f'd="{path}"',
                f'stroke="{color}"',
                'fill="none"',
                f'stroke-width="{STROKE_WIDTH}"',
                'stroke-linecap="round"',
                'stroke-linejoin="round"',
            ]
            dash = LINESTYLE_DASH[linestyle]
            if dash:
                attrs.append(f'stroke-dasharray="{dash}"')
            out.append(f'<path {" ".join(attrs)}/>')

        if marker is not None:
            href = MARKER_HREFS[marker]
            for px, py in coords:
                out.append(
                    f'<use href="{href}" x="{px:.1f}" y="{py:.1f}" '
                    f'color="{color}"/>'
                )

        return out


def render(series_list, log_y=False, width=DEFAULT_WIDTH, height=DEFAULT_HEIGHT,
           styles=None):
    """Render one or two recordings into a complete SVG document.

    `series_list` holds ``(kind, points)`` tuples. With one entry the chart
    has a single y-axis on the left. With two entries the second series is
    plotted against an independent right-hand axis (--double-y).

    `styles` is a list of matplotlib-style format strings, one per series.
    A shorter list is recycled (so passing a single style applies it to
    both series of a double-y chart).
    """
    if not 1 <= len(series_list) <= 2:
        raise ValueError("render expects 1 or 2 series")

    if styles is None:
        styles = DEFAULT_STYLES
    parsed = [
        parse_style(styles[min(i, len(styles) - 1)])
        for i in range(len(series_list))
    ]

    all_xs = [t for _, pts in series_list for t, _ in pts]
    plot = Plot(min(all_xs), max(all_xs), width=width, height=height)

    out = plot.header()

    # Emit <defs> only for markers actually used, so charts that need no
    # markers carry no dead weight.
    markers_used = sorted({m for _, m, _ in parsed if m is not None})
    if markers_used:
        out.append("<defs>" + "".join(MARKER_DEFS[m] for m in markers_used) + "</defs>")

    # Tint the left/right verticals to match their series so each spine
    # visually "owns" its axis. With only one series the right vertical
    # stays black — there's no second series to attach it to.
    left_spine = parsed[0][2]
    right_spine = parsed[1][2] if len(series_list) == 2 else "black"
    out += plot.frame(left_color=left_spine, right_color=right_spine)

    sides = ["left", "right"]
    for i, (kind, pts) in enumerate(series_list):
        linestyle, marker, color = parsed[i]
        axis = Axis(kind, [v for _, v in pts], log=log_y)
        out += plot.y_axis(axis, side=sides[i], color=color)
        out += plot.series(pts, axis, color=color, linestyle=linestyle, marker=marker)

    out += plot.x_axis() + plot.footer()
    return "\n".join(out)


# ---------------------------------------------------------------------------
# Output naming and SVG → PNG conversion
# ---------------------------------------------------------------------------

# Filename timestamp shape requested by the user: dashes everywhere, with a
# double dash separating the date from the time so it stays sortable and
# readable on case-insensitive filesystems.
TIMESTAMP_FORMAT = "%Y-%m-%d--%H-%M-%S"

# SVG → PNG converters tried in order. The first one whose binary is on
# $PATH wins. All four are well-known Linux tools:
#   - librsvg's `rsvg-convert` (smallest dependency, sharpest output)
#   - ImageMagick 7's `magick` and 6's `convert`
#   - Inkscape (heavier, but ubiquitous on desktops)
# If none is installed, the SVG is still written; we just warn that the PNG
# couldn't be produced. Templates use ``{svg}``/``{png}`` for paths and
# ``{w}``/``{h}`` for the requested PNG pixel dimensions.
SVG_TO_PNG_TOOLS = [
    ["rsvg-convert", "-w", "{w}", "-h", "{h}", "-o", "{png}", "{svg}"],
    ["magick", "{svg}", "-resize", "{w}x{h}", "{png}"],
    ["convert", "{svg}", "-resize", "{w}x{h}", "{png}"],
    ["inkscape", "{svg}",
     "--export-type=png",
     "--export-width={w}", "--export-height={h}",
     "--export-filename={png}"],
]


def auto_output_path(series_list):
    """Default SVG path for a chart, e.g. output/ping-2026-05-09--12-30-00.svg.

    The prefix tracks what's being plotted: a single recording uses its
    own kind ("ping" or "curl"); a double-y chart uses "combined" since
    both kinds are on the same plot.
    """
    if len(series_list) == 1:
        prefix = series_list[0][0]  # "ping" or "curl"
    else:
        prefix = "combined"
    ts = datetime.now().strftime(TIMESTAMP_FORMAT)
    return os.path.join(OUTPUT_DIR, f"{prefix}-{ts}.svg")


def svg_to_png(svg_path, svg_width, svg_height, scale=1.0):
    """Render `svg_path` to a sibling .png file.

    The PNG dimensions are ``svg_width × svg_height × scale``, so a
    --png-scale of 2 yields a 2× higher-pixel-count PNG of the same
    chart (handy for retina displays or print).

    Returns the PNG path on success, or None if no converter on the
    system was able to do the job. Stderr from the converter is
    swallowed so a working tool produces clean output; on full failure
    the caller logs a single suggestion line.
    """
    png_path = os.path.splitext(svg_path)[0] + ".png"
    w = max(1, int(round(svg_width * scale)))
    h = max(1, int(round(svg_height * scale)))
    for template in SVG_TO_PNG_TOOLS:
        if not shutil.which(template[0]):
            continue
        cmd = [
            arg.format(svg=svg_path, png=png_path, w=w, h=h)
            for arg in template
        ]
        try:
            subprocess.run(
                cmd, check=True,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
            return png_path
        except subprocess.CalledProcessError:
            continue
    return None


# ---------------------------------------------------------------------------
# Recording
# ---------------------------------------------------------------------------
#
# The recording subcommands shell out to system `ping` / `curl`. Each
# emits one timestamped line per sample to stdout, and (if `-o PATH` was
# given) also writes a copy to that file — i.e. behaves like `tee`. All
# writes are flushed line-by-line so live `tail -f` and downstream pipes
# see updates in real time.

def _open_sinks(output_path):
    """Open the tee sinks. Returns (sinks, file_to_close_when_done).

    The parent directory of `output_path` is created if missing, so the
    default `data/...` location (and any user-supplied path) "just works"
    on a fresh checkout.
    """
    if not output_path:
        return [sys.stdout], None
    parent = os.path.dirname(os.path.abspath(output_path))
    if parent:
        os.makedirs(parent, exist_ok=True)
    f = open(output_path, "w")
    return [sys.stdout, f], f


def _emit(sinks, line):
    for s in sinks:
        s.write(line)
        s.flush()


PING_INTERVAL_SECONDS = 1.0


def record_ping(host, output_path):
    """Send one ping per second, recording each reply with its timestamp.

    Spawns a fresh ``ping -c 1 -D <host>`` process for every probe
    rather than letting a single long-running ``ping`` stream samples.
    The reason is gnosisVPN-specific: a long-running ping reuses the
    same routing/path state inside the tunnel, which the kernel and
    intermediate hops cache. Each new process forces a new DNS lookup,
    a new ICMP socket, and a new tunnel session — giving an honest
    measurement instead of a hot-path one.

    Lines that don't carry a `[ts]` reply (the "PING ... data bytes"
    banner and the per-probe statistics block) are filtered out so the
    recording stays clean and matches the format the plotter expects.
    """
    cmd = ["ping", "-c", "1", "-W", "1", "-D", host]
    sinks, fh = _open_sinks(output_path)
    try:
        while True:
            t0 = time.monotonic()
            try:
                proc = subprocess.run(cmd, capture_output=True, text=True)
            except FileNotFoundError as e:
                sys.exit(str(e))
            for line in proc.stdout.splitlines():
                if TIMESTAMP_RE.search(line):
                    _emit(sinks, line + "\n")
            sleep_for = PING_INTERVAL_SECONDS - (time.monotonic() - t0)
            if sleep_for > 0:
                time.sleep(sleep_for)
    except KeyboardInterrupt:
        pass
    finally:
        if fh is not None:
            fh.close()
    return 0


def record_curl(url, output_path):
    """Run `curl <url> -o /dev/null` and timestamp each progress update.

    curl's progress meter overwrites a single line using `\\r`. We split the
    merged stdout/stderr stream on `\\r` *or* `\\n`, prefix each segment
    with a high-resolution Unix timestamp, and forward the result. This
    is a pure-Python equivalent of the original
    `curl ... 2>&1 | tr '\\r' '\\n' | awk strftime(...) | tee` pipeline,
    minus awk's lack of `%N` (we always get full microseconds).

    The body is discarded with `-o /dev/null` so repeated runs don't
    litter the working directory with downloaded files; we only care
    about the throughput numbers in curl's progress output.
    """
    cmd = ["curl", "-o", "/dev/null", url]
    sinks, fh = _open_sinks(output_path)
    # Merge stderr (where the progress meter lives) into stdout so a single
    # read loop sees everything in order.
    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        bufsize=0,
    )
    buf = bytearray()
    try:
        while True:
            ch = proc.stdout.read(1)
            if not ch:
                if buf:
                    _emit(sinks, _stamp(buf))
                break
            if ch in (b"\r", b"\n"):
                if buf:
                    _emit(sinks, _stamp(buf))
                    buf.clear()
            else:
                buf.extend(ch)
    except KeyboardInterrupt:
        proc.terminate()
    finally:
        proc.wait()
        if fh is not None:
            fh.close()
    return proc.returncode


def _stamp(buf):
    """Format a buffered curl progress segment as one timestamped line."""
    text = bytes(buf).decode("utf-8", "replace")
    return f"[{time.time():.6f}] {text}\n"


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def cmd_plot(args):
    if args.double_y and len(args.files) != 2:
        sys.exit("error: --double-y requires exactly two input files")
    if not args.double_y and len(args.files) != 1:
        sys.exit("error: expected one file (or two with --double-y)")

    try:
        series = [parse_recording(p) for p in args.files]
    except (FileNotFoundError, ValueError) as e:
        sys.exit(str(e))

    try:
        svg = render(
            series, log_y=args.log_y,
            width=args.width, height=args.height,
            styles=args.style,
        )
    except ValueError as e:
        sys.exit(str(e))

    output = args.output if args.output is not None else auto_output_path(series)

    if output == "-":
        # Stdout means no on-disk artefact, so no PNG sibling either.
        sys.stdout.write(svg + "\n")
        return

    parent = os.path.dirname(os.path.abspath(output))
    if parent:
        os.makedirs(parent, exist_ok=True)
    with open(output, "w") as f:
        f.write(svg + "\n")
    sys.stderr.write(f"wrote {output}\n")

    png = svg_to_png(output, args.width, args.height, args.png_scale)
    if png:
        sys.stderr.write(f"wrote {png}\n")
    else:
        sys.stderr.write(
            "note: skipping PNG — install rsvg-convert (apt install librsvg2-bin), "
            "imagemagick, or inkscape to enable.\n"
        )


def cmd_ping(args):
    sys.exit(record_ping(args.host, args.output))


def cmd_curl(args):
    sys.exit(record_curl(args.url, args.output))


def build_parser():
    parser = argparse.ArgumentParser(
        description="Record and plot gnosisVPN ping/curl traces.",
    )
    sub = parser.add_subparsers(dest="cmd", required=True, metavar="{plot,ping,curl}")

    # plot ----------------------------------------------------------------
    p_plot = sub.add_parser(
        "plot",
        help="render an SVG chart from a recording",
        description="Render an SVG line chart from a ping or curl recording.",
    )
    p_plot.add_argument(
        "files",
        nargs="+",
        help="one recording file (single chart) or two for --double-y",
    )
    p_plot.add_argument(
        "--double-y",
        action="store_true",
        help="plot two recordings on independent left/right y-axes",
    )
    p_plot.add_argument(
        "--log-y",
        action="store_true",
        help="use a logarithmic y-axis (applies to both axes in --double-y)",
    )
    p_plot.add_argument(
        "-o", "--output", default=None,
        help=(
            "write SVG to this path. Default: an auto-generated path "
            "output/{ping,curl,combined}-YYYY-MM-DD--HH-MM-SS.svg "
            "with a sibling .png. Pass '-' to write SVG to stdout "
            "(no PNG companion in that case)."
        ),
    )
    p_plot.add_argument(
        "--width", type=int, default=DEFAULT_WIDTH,
        help=f"SVG width in pixels (default: {DEFAULT_WIDTH})",
    )
    p_plot.add_argument(
        "--height", type=int, default=DEFAULT_HEIGHT,
        help=f"SVG height in pixels (default: {DEFAULT_HEIGHT})",
    )
    p_plot.add_argument(
        "--png-scale", type=float, default=1.0,
        help="multiplier applied to the SVG dimensions when rendering the "
             "PNG (e.g. 2.0 doubles the PNG's pixel count for retina/print). "
             "Default: 1.0",
    )
    p_plot.add_argument(
        "--style", nargs="+", default=DEFAULT_STYLES, metavar="STYLE",
        help=(
            "matplotlib-style format string, one per series. Combine "
            "linestyle (- -- -. :), marker (. o x + * s D ^ v) and "
            "colour (b g r c m y k w) in any order. Examples: "
            "'xb' (default — blue x markers, no line); 'o-r' (red solid "
            "line + open circles); '.--g' (green dashed line + dots). "
            f"Default: {' '.join(DEFAULT_STYLES)} "
            "(first style for the left axis, second for the right)."
        ),
    )
    p_plot.set_defaults(func=cmd_plot)

    # ping ----------------------------------------------------------------
    p_ping = sub.add_parser(
        "ping",
        help="record ping latency to a host",
        description="Record `ping -D <host>` to stdout (and optionally to a file).",
    )
    p_ping.add_argument(
        "host",
        nargs="?",
        default=DEFAULT_PING_HOST,
        help=f"host to ping (default: {DEFAULT_PING_HOST})",
    )
    p_ping.add_argument(
        "-o", "--output",
        default=DEFAULT_PING_FILE,
        help=f"also write a copy of the trace to this path "
             f"(default: {os.path.relpath(DEFAULT_PING_FILE, PROJECT_ROOT)}; "
             f"pass an empty string to skip the file copy)",
    )
    p_ping.set_defaults(func=cmd_ping)

    # curl ----------------------------------------------------------------
    p_curl = sub.add_parser(
        "curl",
        help="record curl download throughput",
        description=(
            "Download a URL with curl and record its progress meter, "
            "one timestamped line per update. The body is discarded "
            "(curl -o /dev/null)."
        ),
    )
    p_curl.add_argument(
        "url",
        nargs="?",
        default=DEFAULT_CURL_URL,
        help=f"URL to download (default: {DEFAULT_CURL_URL})",
    )
    p_curl.add_argument(
        "-o", "--output",
        default=DEFAULT_CURL_FILE,
        help=f"also write a copy of the trace to this path "
             f"(default: {os.path.relpath(DEFAULT_CURL_FILE, PROJECT_ROOT)}; "
             f"pass an empty string to skip the file copy)",
    )
    p_curl.set_defaults(func=cmd_curl)

    return parser


def main(argv=None):
    args = build_parser().parse_args(argv)
    args.func(args)


if __name__ == "__main__":
    main()
